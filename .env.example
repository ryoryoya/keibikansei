# ============================================================
# 警備管制システム - 環境変数
# このファイルをコピーして .env.local を作成してください
# cp .env.example .env.local
# ============================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Database (Supabase PostgreSQL) ---
# Transaction mode (for Prisma Client)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# Session mode (for Prisma Migrate)
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres

# --- NextAuth / Auth ---
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# --- Google Maps ---
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-key

# --- Firebase (Push Notifications) ---
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_SERVER_KEY=your-firebase-server-key

# --- SendGrid (Email) ---
SENDGRID_API_KEY=your-sendgrid-key
SENDGRID_FROM_EMAIL=noreply@your-domain.com

# --- File Storage ---
# Supabase Storageを使用する場合は追加設定不要
# S3互換の場合は以下を設定
# S3_BUCKET=keibi-reports
# S3_REGION=ap-northeast-1
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=警備管制システム
