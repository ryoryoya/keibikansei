// 特定日の配置可能な隊員を取得
export async function getAvailableGuards(
  orgId: string,
  date: string,
  projectId?: string
) {
  const targetDate = new Date(date);

  // 全隊員を取得
  const allGuards = await prisma.user.findMany({
    where: { orgId, role: "GUARD", isActive: true },
    include: { guardProfile: true },
  });

  // その日の既存配置を取得
  const existingAssignments = await prisma.assignment.findMany({
    where: {
      workDate: targetDate,
      status: { not: "CANCELLED" },
      project: { orgId },
    },
    select: { userId: true, projectId: true },
  });

  // シフト提出を取得
  const shifts = await prisma.shiftSubmission.findMany({
    where: {
      targetDate,
      userId: { in: allGuards.map((g) => g.id) },
    },
  });

  const shiftMap = new Map(shifts.map((s) => [s.userId, s]));
  const assignedSet = new Set(existingAssignments.map((a) => a.userId));

  return allGuards.map((guard) => {
    const shift = shiftMap.get(guard.id);
    const isAssigned = assignedSet.has(guard.id);
    const assignedToThisProject = existingAssignments.some(
      (a) => a.userId === guard.id && a.projectId === projectId
    );

    return {
      ...guard,
      shiftStatus: shift?.availability || "UNDECIDED",
      isAssigned,
      assignedToThisProject,
      isAvailable:
        !isAssigned &&
        shift?.availability !== "NG" &&
        shift?.availability !== undefined,
    };
  });
}

// 隊員を案件に配置
export async function assignGuard(params: {
  projectId: string;
  userId: string;
  workDate: string;
  plannedStart: string;
  plannedEnd: string;
}) {
  const { projectId, userId, workDate, plannedStart, plannedEnd } = params;

  // 重複チェック
  const existing = await prisma.assignment.findUnique({
    where: {
      projectId_userId_workDate: {
        projectId,
        userId,
        workDate: new Date(workDate),
      },
    },
  });

  if (existing && existing.status !== "CANCELLED") {
    throw new Error("この隊員は既にこの案件に配置されています");
  }

  if (existing) {
    // キャンセル済みの場合は復活
    return prisma.assignment.update({
      where: { id: existing.id },
      data: { status: "PENDING", plannedStart, plannedEnd },
    });
  }

  return prisma.assignment.create({
    data: {
      projectId,
      userId,
      workDate: new Date(workDate),
      plannedStart,
      plannedEnd,
      status: "PENDING",
    },
  });
}

// 配置を一括作成（複数日）
export async function assignGuardBulk(params: {
  projectId: string;
  userId: string;
  dates: string[];
  plannedStart: string;
  plannedEnd: string;
}) {
  const { projectId, userId, dates, plannedStart, plannedEnd } = params;

  const results = [];
  for (const date of dates) {
    try {
      const result = await assignGuard({
        projectId,
        userId,
        workDate: date,
        plannedStart,
        plannedEnd,
      });
      results.push({ date, success: true, data: result });
    } catch (error: any) {
      results.push({ date, success: false, error: error.message });
    }
  }

  return results;
}

// 配置をキャンセル
export async function cancelAssignment(assignmentId: string) {
  return prisma.assignment.update({
    where: { id: assignmentId },
    data: { status: "CANCELLED" },
  });
}

// 配置を確定
export async function confirmAssignment(assignmentId: string) {
  return prisma.assignment.update({
    where: { id: assignmentId },
    data: { status: "CONFIRMED", confirmedAt: new Date() },
  });
}

// 特定日の配置一覧（当日管理画面用）
export async function getDailyAssignments(orgId: string, date: string) {
  return prisma.assignment.findMany({
    where: {
      workDate: new Date(date),
      status: { not: "CANCELLED" },
      project: { orgId },
    },
    include: {
      user: { include: { guardProfile: true } },
      project: { include: { site: { include: { client: true } } } },
      attendances: true,
      guardReports: true,
    },
    orderBy: [
      { project: { name: "asc" } },
      { plannedStart: "asc" },
    ],
  });
}
