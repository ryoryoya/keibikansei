"use server";

import prisma from "@/lib/prisma";
import { startOfMonth, endOfMonth, eachDayOfInterval, format } from "date-fns";
import type { CalendarDay } from "@/types";

// ============================================================
// 案件取得
// ============================================================
export async function getProjects(orgId: string, status?: string) {
  return prisma.project.findMany({
    where: {
      orgId,
      ...(status ? { status: status as any } : {}),
    },
    include: {
      site: { include: { client: true } },
      assignments: { include: { user: true } },
    },
    orderBy: { startDate: "asc" },
  });
}

export async function getProjectById(projectId: string) {
  return prisma.project.findUnique({
    where: { id: projectId },
    include: {
      site: { include: { client: true } },
      assignments: {
        include: {
          user: { include: { guardProfile: true } },
          attendances: true,
        },
        orderBy: { workDate: "asc" },
      },
    },
  });
}

// ============================================================
// カレンダーデータ取得（月単位）
// ============================================================
export async function getCalendarData(
  orgId: string,
  year: number,
  month: number
): Promise<CalendarDay[]> {
  const monthStart = startOfMonth(new Date(year, month - 1));
  const monthEnd = endOfMonth(new Date(year, month - 1));

  // 月内のアクティブ案件を取得
  const projects = await prisma.project.findMany({
    where: {
      orgId,
      status: "ACTIVE",
      startDate: { lte: monthEnd },
      OR: [{ endDate: null }, { endDate: { gte: monthStart } }],
    },
    include: {
      site: { include: { client: true } },
    },
  });

  // 月内の配置を取得
  const assignments = await prisma.assignment.findMany({
    where: {
      project: { orgId },
      workDate: { gte: monthStart, lte: monthEnd },
      status: { not: "CANCELLED" },
    },
    select: {
      projectId: true,
      workDate: true,
    },
  });

  // 日別に配置数を集計
  const assignmentCounts = new Map<string, Map<string, number>>();
  for (const a of assignments) {
    const dateKey = format(a.workDate, "yyyy-MM-dd");
    if (!assignmentCounts.has(dateKey)) {
      assignmentCounts.set(dateKey, new Map());
    }
    const dayMap = assignmentCounts.get(dateKey)!;
    dayMap.set(a.projectId, (dayMap.get(a.projectId) || 0) + 1);
  }

  // カレンダーデータを構築
  const days = eachDayOfInterval({ start: monthStart, end: monthEnd });

  return days.map((day) => {
    const dateKey = format(day, "yyyy-MM-dd");
    const dayAssignments = assignmentCounts.get(dateKey) || new Map();

    const dayProjects = projects
      .filter((p) => {
        const start = new Date(p.startDate);
        const end = p.endDate ? new Date(p.endDate) : monthEnd;
        return day >= start && day <= end;
      })
      .map((p) => {
        const assignedGuards = dayAssignments.get(p.id) || 0;
        return {
          id: p.id,
          name: p.name,
          siteName: p.site.name,
          clientName: p.site.client.name,
          requiredGuards: p.requiredGuards,
          assignedGuards,
          startTime: p.startTime,
          endTime: p.endTime,
          status:
            assignedGuards >= p.requiredGuards
              ? ("sufficient" as const)
              : assignedGuards > 0
              ? ("shortage" as const)
              : ("empty" as const),
        };
      });

    return { date: dateKey, projects: dayProjects };
  });
}

